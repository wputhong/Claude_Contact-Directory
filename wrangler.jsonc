{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "contact-directory",
  "main": "contact-directory/site-worker.js",
  "compatibility_date": "2026-07-20",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "contact-directory",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
