{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "claude-contact-directory",
  "main": "contact-directory/site-worker.js",
  "compatibility_date": "2026-07-20",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "contact-directory",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "secrets_store_secrets": [
    {
      "binding": "ANTHROPIC_API_KEY",
      "store_id": "f4379e9cde85464884daec7e780c5a88",
      "secret_name": "ANTHROPIC_API_KEY"
    }
  ]
}
